{$APP_DOMAIN} {
  encode gzip zstd

  handle_path /api/* {
    reverse_proxy api:4000
  }

  handle_path /media/* {
    root * /data/hontho-media
    file_server
    header Cache-Control "public, max-age=31536000, immutable"
  }

  handle {
    root * /srv/app
    try_files {path} /index.html
    file_server
  }
}
