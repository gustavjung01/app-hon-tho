# Copy to .env on local/VPS. Do not commit real secrets.
API_PORT=4000
CORS_ORIGIN=http://localhost:5173

# Neon/Postgres. Put the real Neon URL here on the machine, not in Git.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Clerk server-side auth.
CLERK_SECRET_KEY=sk_test_xxx

# Bootstrap admin. Use Clerk user IDs first. Emails work only if the Clerk JWT carries an email claim.
ADMIN_CLERK_USER_IDS=user_xxx,user_yyy
ADMIN_EMAILS=admin@example.com

# Legacy fallback for old JWT endpoints.
JWT_SECRET=change_me
BANK_TRANSFER_PREFIX=HT
EMAIL_PROVIDER=stub
